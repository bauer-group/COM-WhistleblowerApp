# ═══════════════════════════════════════════════════════════
# Whistleblower-App (GlobaLeaks) - Environment Configuration
# BAUER GROUP | Compliance Reporting Platform (HinSchG / EU 2019/1937)
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your environment
# Usage: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# Stack Identification
# ─────────────────────────────────────────────────────────────
STACK_NAME=compliance_app_bauer-group_com

# ─────────────────────────────────────────────────────────────
# Common Settings
# ─────────────────────────────────────────────────────────────
TIME_ZONE=Etc/UTC

# GlobaLeaks image tag.
# Use a pinned digest in production for supply-chain integrity:
#   GLOBALEAKS_IMAGE=globaleaks/globaleaks@sha256:<digest>
GLOBALEAKS_IMAGE=globaleaks/globaleaks:latest

# ─────────────────────────────────────────────────────────────
# Hostname / Public Endpoint
# ─────────────────────────────────────────────────────────────
GLOBALEAKS_HOSTNAME=compliance.app.bauer-group.com

# Development only:
GLOBALEAKS_HTTP_PORT=8080
GLOBALEAKS_HTTPS_PORT=8443

# ─────────────────────────────────────────────────────────────
# Reverse Proxy Mode (Traefik / Coolify)
# ─────────────────────────────────────────────────────────────
# Variant B: Traefik terminates TLS, forwards plain HTTP to GlobaLeaks:8080.
# After first boot you MUST configure GlobaLeaks for reverse-proxy mode in
# the admin panel:
#   Admin → Settings → Network → "Behind a reverse proxy: ON"
#   Admin → Settings → HTTPS → "Disable Let's Encrypt" (Traefik handles TLS)
#
# Background: GlobaLeaks ships its own ACME client. Behind Traefik this would
# fight Traefik for port 80/443 and fail. Disable it once via the admin UI.

# ─────────────────────────────────────────────────────────────
# Tor Onion Service (configurable on/off)
# ─────────────────────────────────────────────────────────────
# Tor is bundled inside the GlobaLeaks container. Toggle the Onion Service
# in the admin panel:
#   Admin → Settings → Network → "Tor: ON"
#
# The .onion address persists in the volume (/var/globaleaks/backend/tor).
# To disable Tor entirely (network policy), use the development compose with
# --profile no-tor (blocks outbound 9001/9030/9050 via no_tor sidecar).
ENABLE_TOR=true

# ─────────────────────────────────────────────────────────────
# Resource Limits (optional - DoS protection)
# Docs: https://docs.docker.com/compose/compose-file/deploy/#resources
# ─────────────────────────────────────────────────────────────
# GlobaLeaks (Python/Twisted - moderate footprint)
# GLOBALEAKS_CPU_LIMIT=2.0
# GLOBALEAKS_MEM_LIMIT=1024M

# ─────────────────────────────────────────────────────────────
# Network (Production)
# ─────────────────────────────────────────────────────────────
PROXY_NETWORK=EDGEPROXY

# ─────────────────────────────────────────────────────────────
# Deployment Commands
# ─────────────────────────────────────────────────────────────
# Development (direct port access, no TLS):
#   docker compose -f docker-compose.development.yml up -d
#
# Production behind Traefik (TLS terminated by Traefik):
#   docker compose -f docker-compose.traefik.yml up -d
#
# Coolify managed deployment:
#   docker compose -f docker-compose.coolify.yml up -d
#
# ─────────────────────────────────────────────────────────────
# First-Boot Setup
# ─────────────────────────────────────────────────────────────
# 1. Open https://compliance.app.bauer-group.com (or http://localhost:8080)
# 2. Wizard:
#    - Choose language (DE)
#    - Set admin password (min 16 chars, store in vault)
#    - Set recipient (compliance officer email)
# 3. Admin → Settings → Network: enable "Behind reverse proxy"
# 4. Admin → Settings → HTTPS: disable Let's Encrypt
# 5. Admin → Settings → Network → Tor: enable if ENABLE_TOR=true
# 6. Admin → Notifications: configure SMTP for recipient alerts
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# Backup (manual via gl-admin)
# ─────────────────────────────────────────────────────────────
# Inside container:
#   docker exec -it ${STACK_NAME}_SERVER gl-admin backup
#   docker cp ${STACK_NAME}_SERVER:/tmp/globaleaks_backup_YY_MM_DD.tar.gz ./
#
# Restore:
#   docker cp ./globaleaks_backup_YY_MM_DD.tar.gz ${STACK_NAME}_SERVER:/tmp/
#   docker exec -it ${STACK_NAME}_SERVER gl-admin restore /tmp/globaleaks_backup_YY_MM_DD.tar.gz
# ─────────────────────────────────────────────────────────────
