# ═══════════════════════════════════════════════════════════
# Whistleblower-App (GlobaLeaks) - Environment Configuration
# BAUER GROUP | Compliance Reporting Platform (HinSchG / EU 2019/1937)
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your environment
# Usage: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# Stack Identification
# ─────────────────────────────────────────────────────────────
STACK_NAME=speakup_bauer-group_com

# ─────────────────────────────────────────────────────────────
# Common Settings
# ─────────────────────────────────────────────────────────────
TIME_ZONE=Etc/UTC

# Upstream-GlobaLeaks-Version, auf die das BAUER-GROUP-Image in src/Dockerfile
# aufbaut. Das lokale Image wird bei `docker compose up --build` aus src/ gebaut.
# Für reproduzierbare Production-Deploys einen Release-Tag pinnen (z.B. "5.0.89").
GLOBALEAKS_BASE_VERSION=latest

# ─────────────────────────────────────────────────────────────
# Hostname / Public Endpoint
# ─────────────────────────────────────────────────────────────
GLOBALEAKS_HOSTNAME=speakup.bauer-group.com

# Development only (Host-Port-Mapping in docker-compose.development.yml):
GLOBALEAKS_HTTP_PORT=8080

# ─────────────────────────────────────────────────────────────
# Reverse Proxy Mode (Traefik / Coolify)
# ─────────────────────────────────────────────────────────────
# Das BAUER-GROUP-Image (siehe src/Dockerfile) patcht GlobaLeaks so, dass
# X-Forwarded-Proto vom Reverse Proxy respektiert wird. Dadurch funktioniert
# Plain-HTTP-Forwarding vom Proxy intern zu :8080 ohne Redirect-Loop.
#
# Nach dem Wizard:
#   Admin → Settings → HTTPS → "Let's Encrypt: DEAKTIVIEREN"
#   (Proxy macht das public TLS, GlobaLeaks darf nicht selbst für 80/443 kämpfen)

# ─────────────────────────────────────────────────────────────
# Tor Onion Service
# ─────────────────────────────────────────────────────────────
# Tor ist im GlobaLeaks-Image gebündelt und wird NICHT per ENV-Var
# geschaltet — die Aktivierung erfolgt post-Wizard in der Admin-UI:
#   Admin → Settings → Network → "Tor: ON"
#
# Die .onion-Adresse persistiert im Daten-Volume. Kein Compose-Eingriff nötig.

# ─────────────────────────────────────────────────────────────
# Resource Limits (optional - DoS protection)
# Docs: https://docs.docker.com/compose/compose-file/deploy/#resources
# ─────────────────────────────────────────────────────────────
# GlobaLeaks (Python/Twisted - moderate footprint)
# GLOBALEAKS_CPU_LIMIT=2.0
# GLOBALEAKS_MEM_LIMIT=1024M

# ─────────────────────────────────────────────────────────────
# Network (Production)
# ─────────────────────────────────────────────────────────────
PROXY_NETWORK=EDGEPROXY

# ─────────────────────────────────────────────────────────────
# Deployment Commands
# ─────────────────────────────────────────────────────────────
# Development (direkter Port-Zugriff):
#   docker compose -f docker-compose.development.yml up -d --build
#
# Production hinter Traefik (TLS über Traefik):
#   docker compose -f docker-compose.traefik.yml up -d --build
#
# Coolify (cloned Git-Repo, baut selbst):
#   Als "Docker Compose" Resource mit Git-Quelle anlegen.
#
# ─────────────────────────────────────────────────────────────
# First-Boot Setup
# ─────────────────────────────────────────────────────────────
# 1. Öffne https://speakup.bauer-group.com (bzw. http://localhost:8080 im Dev)
# 2. Wizard:
#    - Sprache (DE)
#    - Admin-Passwort (min. 16 Zeichen, in Vault speichern)
#    - Compliance-Officer als Recipient
# 3. Admin → Settings → HTTPS: Let's Encrypt DEAKTIVIEREN
# 4. Admin → Settings → Network → Tor: aktivieren (falls Onion Service gewünscht)
# 5. Admin → Notifications: SMTP konfigurieren
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# Backup (manual via gl-admin)
# ─────────────────────────────────────────────────────────────
# Inside container:
#   docker exec -it ${STACK_NAME}_SERVER gl-admin backup
#   docker cp ${STACK_NAME}_SERVER:/tmp/globaleaks_backup_YY_MM_DD.tar.gz ./
#
# Restore:
#   docker cp ./globaleaks_backup_YY_MM_DD.tar.gz ${STACK_NAME}_SERVER:/tmp/
#   docker exec -it ${STACK_NAME}_SERVER gl-admin restore /tmp/globaleaks_backup_YY_MM_DD.tar.gz
# ─────────────────────────────────────────────────────────────
